{
  "name": "fast-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:https": "next build && next start & local-ssl-proxy --source 3001 --target 3000 --cert certificates/localhost.pem --key certificates/localhost-key.pem",
    "lint": "biome check",
    "format": "biome format --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "@tanstack/query-async-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@serwist/turbopack": "^9.5.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web": "^0.0.339",
    "babel-plugin-react-compiler": "1.0.0",
    "daisyui": "^5.5.19",
    "esbuild": "^0.27.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "local-ssl-proxy": "^2.0.5",
    "postcss": "^8",
    "serwist": "^9.5.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "browserslist": "> 1%"
}
